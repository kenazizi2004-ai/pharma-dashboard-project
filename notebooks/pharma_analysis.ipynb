import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("../data/processed/cleaned_pharma_data.csv")

df.head()

print(df.info())
print(df.describe())

drug_success = df.groupby("drug_name")["success_rate"].mean()

print(drug_success)

company_perf = df.groupby("company")["success_rate"].mean()

company_perf.plot(kind="bar")

plt.title("Average Drug Success Rate by Company")
plt.xlabel("Company")
plt.ylabel("Success Rate")

plt.show()

risk_phase = df.groupby("trial_phase")["risk_score"].mean()

risk_phase.plot(kind="line", marker="o")

plt.title("Risk Score by Trial Phase")
plt.xlabel("Trial Phase")
plt.ylabel("Risk Score")

plt.show()

correlation = df[["success_rate", "side_effect_rate", "risk_score"]].corr()

print(correlation)
